# Copy to .env (the installer does this for you). NEVER commit your real .env.

# --- Required: Claude subscription auth ---
# Your Claude Code OAuth token (run `claude setup-token`, or the installer prompts).
CLAUDE_CODE_OAUTH_TOKEN=
# Left blank ON PURPOSE so the subscription token is used (not an API key).
ANTHROPIC_API_KEY=

# --- Runtime ---
SENTINEL_RUNNER_MODE=docker        # docker (real sandbox) | local (dev)
SENTINEL_EGRESS=jail               # jail (kernel egress jail) | none | bridge
SENTINEL_PROXY_PASSTHROUGH=off     # off = fail-closed (only auth-hosts reachable). on = agent may reach
                                   #   ANY host (open web); keys are STILL only injected for auth-hosts,
                                   #   but a hijacked run could exfiltrate to an arbitrary host. SSRF
                                   #   (loopback/link-local/metadata/private IPs) stays blocked either way.
SENTINEL_MODEL=claude-haiku-4-5    # model for turns
SENTINEL_SURFACES=slack            # comma-separated surfaces the daemon starts
SENTINEL_TZ=UTC                    # timezone for cron schedules, e.g. Europe/London

# --- Slack (create an app from sentinel-slack-manifest.json) ---
SLACK_APP_TOKEN=                   # xapp-...
SLACK_BOT_TOKEN=                   # xoxb-...
SENTINEL_SLACK_ALLOWED_USERS=      # comma-separated Slack member ids (U...)

# --- Optional features ---
SENTINEL_REFLECT=off               # on = distil durable facts into memory after chats
SENTINEL_HOSTOPS=off               # on = enable the file_write host-ops tool
# SENTINEL_BUDGET_USD=             # soft cost cap (mainly for the API-key path)

# Service secrets for mediated tools go in the vault, not here:
#   SENTINEL_VAULT_<KEY>=...   (or a host-only SENTINEL_VAULT_FILE=path/to/secrets.json)
