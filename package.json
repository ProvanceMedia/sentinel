{
  "name": "sentinel",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "description": "Flagship personal Claude agent on the Agent SDK — per-session container isolation, sub-first auth.",
  "engines": { "node": ">=20" },
  "scripts": {
    "sentinel": "tsx src/surfaces/cli.ts",
    "sentineld": "tsx src/main.ts",
    "connect": "tsx src/surfaces/connect.ts",
    "runner": "tsx src/runner/agent-runner.ts",
    "gen-ca": "tsx scripts/gen-ca.ts",
    "build:image": "tsx scripts/gen-ca.ts && docker build -f Dockerfile.runner -t sentinel-runner:dev .",
    "typecheck": "tsc --noEmit",
    "check": "tsx scripts/check-core-clean.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.167",
    "@slack/socket-mode": "^2.0.4",
    "@slack/web-api": "^7.10.0",
    "cron-parser": "^5.0.0",
    "node-forge": "^1.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
